---
import Header from "../components/Header.astro";

interface Props {
  title?: string;
}

const { title = "Sketching Tools Hub" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
</body>
</html>
