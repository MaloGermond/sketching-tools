---
interface Props {
  title?: string;
}

const { title = "Sketching Tools Hub" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Hub d'outils de sketching pour la compagnie" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen bg-gray-50">
  <Header />
  <main class="container mx-auto px-4 py-8">
    <slot />
  </main>
  <footer class="text-center py-4 text-gray-500 text-sm">
    <p>Sketching Tools - {new Date().getFullYear()}</p>
  </footer>
</body>
</html>
