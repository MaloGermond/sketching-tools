---
import MainLayout from "../../layouts/MainLayout.astro";

// Métadonnées pour l'affichage dans le hub
const title = "Générateur de motifs";
const description = "Crée des motifs répétitifs et paramétriques pour le sketching";
const icon = "🔄";
const color = "green";
---

<MainLayout title={title}>
  <div class="max-w-4xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{title}</h1>
      <p class="text-gray-600">{description}</p>
    </header>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">À venir</h2>
      <p class="text-gray-600">
        Cet outil permettra de générer des motifs répétitifs avec différents paramètres.
        p5.js sera utilisé pour le rendu visuel.
      </p>
    </section>

    <!-- Zone de visualisation -->
    <div class="bg-white rounded-lg shadow-md p-4 mb-8">
      <div id="pattern-container" class="w-full h-96 border-2 border-dashed border-gray-300 rounded flex items-center justify-center">
        <p class="text-gray-400">Motif généré ici</p>
      </div>
    </div>

    <div class="text-sm text-gray-500">
      <p>⚠️ p5.js doit être installé pour que cet outil fonctionne.</p>
      <p>Exécute: <code class="bg-gray-100 px-2 py-1 rounded">npm install p5</code></p>
    </div>
  </div>
</MainLayout>
