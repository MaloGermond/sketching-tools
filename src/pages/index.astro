---
import MainLayout from "../layouts/MainLayout.astro";
import ToolCard from "../components/ToolCard.astro";

const tools = [
  { title: "Canvas de dessin", href: "/tools/drawing-canvas", icon: "🎨", color: "blue", description: "Dessiner avec p5.js" },
  { title: "Générateur de motifs", href: "/tools/pattern-generator", icon: "🔄", color: "green", description: "Créer des motifs" },
  { title: "Échauffement", href: "/tools/warmup", icon: "🔥", color: "orange", description: "Échauffez-vous avant de dessiner" },
];
---

<MainLayout title="Hub">
  <h1>Mes outils</h1>
  
  <div style="display: grid; gap: 1rem; margin-top: 2rem;">
    {tools.map((tool) => (
      <ToolCard title={tool.title} href={tool.href} icon={tool.icon} color={tool.color} description={tool.description} />
    ))}
  </div>
</MainLayout>

