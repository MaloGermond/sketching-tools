---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  color?: string;
}

const { title, description, href, icon = "🛠️", color = "#667eea" } = Astro.props;
---

<a href={href} class="tool-card" style="border-left-color: {color};">
  <div class="tool-card__container">
    <div class="tool-card__header">
      <span class="tool-card__icon">{icon}</span>
      <h3 class="tool-card__title">{title}</h3>
    </div>
    <p class="tool-card__description">{description}</p>
  </div>
</a>
