---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  color?: string;
}

const { title, description, href, icon = "🛠️", color = "#667eea" } = Astro.props;
---

<a href={href} style="text-decoration: none; display: block;">
  <div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 1.5rem; margin-bottom: 1rem; transition: transform 0.2s, box-shadow 0.2s; border-left: 4px solid {color};">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
      <span style="font-size: 1.5rem;">{icon}</span>
      <h3 style="margin: 0; font-size: 1.25rem; color: #333;">{title}</h3>
    </div>
    <p style="margin: 0; color: #666; line-height: 1.5;">{description}</p>
  </div>
</a>
